#!/usr/bin/env python3
import json
import sys


def main():
    if len(sys.argv) != 2:
        print(f"Usage: {sys.argv[0]} <file.json>")
        sys.exit(1)

    path = sys.argv[1]

    with open(path) as f:
        data = json.load(f)

    if not isinstance(data, list):
        print("Error: JSON root must be a list", file=sys.stderr)
        sys.exit(1)

    data.sort()

    with open(path, "w") as f:
        json.dump(data, f, indent=2)
        f.write("\n")

    print(f"Sorted {len(data)} items in {path}")


if __name__ == "__main__":
    main()
