#!/usr/bin/env python3

import argparse
import json
import os
import subprocess
import sys
from datetime import datetime, timezone
from typing import Any, Dict, List


def get_nodes_data(ctx: str) -> List[Dict[str, Any]]:
    """Get nodes data from kubectl in JSON format."""
    try:
        result = subprocess.run(
            ["kubectl", "get", "nodes", "-o", "json", "--context", ctx],
            capture_output=True,
            text=True,
            check=True,
        )
        return json.loads(result.stdout)["items"]
    except subprocess.CalledProcessError as e:
        print(f"Error running kubectl: {e}", file=sys.stderr)
        sys.exit(1)
    except json.JSONDecodeError as e:
        print(f"Error parsing JSON: {e}", file=sys.stderr)
        sys.exit(1)


def format_age(creation_timestamp: str) -> str:
    """Convert ISO timestamp to human-readable age."""
    try:
        created = datetime.fromisoformat(creation_timestamp.replace("Z", "+00:00"))
        now = datetime.now(timezone.utc)
        elapsed = now - created

        total_seconds = int(elapsed.total_seconds())

        if total_seconds < 60:
            return f"{total_seconds}s"
        elif total_seconds < 3600:
            minutes = total_seconds // 60
            seconds = total_seconds % 60
            return f"{minutes}m{seconds}s"
        elif total_seconds < 86400:
            hours = total_seconds // 3600
            minutes = (total_seconds % 3600) // 60
            return f"{hours}h{minutes}m" if minutes > 0 else f"{hours}h"
        else:
            days = total_seconds // 86400
            hours = (total_seconds % 86400) // 3600
            return f"{days}d{hours}h" if hours > 0 else f"{days}d"
    except Exception:
        return creation_timestamp


def get_node_status(node: Dict[str, Any]) -> str:
    """Extract node ready status."""
    conditions = node.get("status", {}).get("conditions", [])
    for condition in conditions:
        if condition.get("type") == "Ready":
            return "Ready" if condition.get("status") == "True" else "NotReady"
    return "Unknown"


def get_taints(node: Dict[str, Any]) -> str:
    """Extract node taints."""
    taints = node.get("spec", {}).get("taints", [])
    if not taints:
        return "<none>"
    return ",".join([taint.get("key", "") for taint in taints])


def get_label_value(node: Dict[str, Any], label_key: str) -> str:
    """Get label value or return <none> if not found."""
    labels = node.get("metadata", {}).get("labels", {})
    return labels.get(label_key, "<none>")


# Labels AWS / Karpenter sometimes set for subnet (try in order).
_SUBNET_LABEL_KEYS = (
    "karpenter.k8s.aws/instance-subnet-id",
    "eks.amazonaws.com/sourceSubnetId",
)


def get_subnet_from_labels(node: Dict[str, Any]) -> str:
    """Subnet ID from node labels if the provider exposes it."""
    labels = node.get("metadata", {}).get("labels", {})
    for key in _SUBNET_LABEL_KEYS:
        val = labels.get(key)
        if val:
            return val
    return "<none>"


def get_region_from_node(node: Dict[str, Any]) -> str:
    """AWS region from topology label or provider ID."""
    r = get_label_value(node, "topology.kubernetes.io/region")
    if r != "<none>":
        return r
    provider_id = node.get("spec", {}).get("providerID", "")
    if provider_id.startswith("aws://"):
        # aws:///us-west-2a/i-xxx -> zone, instance after stripping prefix
        rest = provider_id.replace("aws://", "", 1).strip("/")
        parts = [p for p in rest.split("/") if p]
        if len(parts) >= 1:
            zone = parts[0]
            if len(zone) >= 2 and zone[-1].isalpha():
                return zone[:-1]
    return ""


def fetch_subnet_ids_from_aws(instance_ids: List[str], region: str) -> Dict[str, str]:
    """Map instance ID -> subnet ID via EC2 API (same region as the cluster)."""
    if not region or not instance_ids:
        return {}
    try:
        result = subprocess.run(
            [
                "aws",
                "ec2",
                "describe-instances",
                "--region",
                region,
                "--instance-ids",
                *instance_ids,
                "--query",
                "Reservations[].Instances[].[InstanceId,SubnetId]",
                "--output",
                "json",
            ],
            capture_output=True,
            text=True,
            check=True,
        )
        pairs = json.loads(result.stdout)
        return {pair[0]: pair[1] for pair in pairs if len(pair) >= 2}
    except (subprocess.CalledProcessError, FileNotFoundError, json.JSONDecodeError):
        return {}


def fetch_subnet_id_to_name(subnet_ids: List[str], region: str) -> Dict[str, str]:
    """
    Map subnet ID -> Name tag (one describe-subnets batch per chunk; each id queried once).
    If there is no Name tag, value is the subnet id.
    """
    if not region or not subnet_ids:
        return {}
    unique = list(dict.fromkeys(s for s in subnet_ids if s.startswith("subnet-")))
    if not unique:
        return {}
    out: Dict[str, str] = {}
    chunk_size = 200
    for i in range(0, len(unique), chunk_size):
        chunk = unique[i : i + chunk_size]
        try:
            result = subprocess.run(
                [
                    "aws",
                    "ec2",
                    "describe-subnets",
                    "--region",
                    region,
                    "--subnet-ids",
                    *chunk,
                    "--output",
                    "json",
                ],
                capture_output=True,
                text=True,
                check=True,
            )
            data = json.loads(result.stdout)
            for sn in data.get("Subnets", []):
                sid = sn.get("SubnetId", "")
                if not sid:
                    continue
                name = ""
                for tag in sn.get("Tags") or []:
                    if tag.get("Key") == "Name":
                        name = (tag.get("Value") or "").strip()
                        break
                out[sid] = name if name else sid
        except (subprocess.CalledProcessError, FileNotFoundError, json.JSONDecodeError):
            continue
    return out


def get_node_ip(node: Dict[str, Any]) -> str:
    """Get node internal IP address."""
    addresses = node.get("status", {}).get("addresses", [])
    for address in addresses:
        if address.get("type") == "InternalIP":
            return address.get("address", "<none>")
    return "<none>"


def get_instance_id(node: Dict[str, Any]) -> str:
    """Extract EC2 instance ID from provider ID."""
    provider_id = node.get("spec", {}).get("providerID", "")
    if provider_id and provider_id.startswith("aws://"):
        # Format: aws:///us-west-2a/i-0e2b7529d1f556c1b
        parts = provider_id.split("/")
        if len(parts) >= 2:
            return parts[-1]  # Last part is the instance ID
    return "<none>"


def print_nodes_table(nodes: List[Dict[str, Any]], *, include_subnets: bool):
    """Print formatted table of nodes."""
    rows = []
    for node in nodes:
        name = node.get("metadata", {}).get("name", "")
        status = get_node_status(node)
        taints = get_taints(node)
        age = format_age(node.get("metadata", {}).get("creationTimestamp", ""))
        instance_type = get_label_value(node, "node.kubernetes.io/instance-type")
        nodepool = get_label_value(node, "karpenter.sh/nodepool")
        capacity = get_label_value(node, "karpenter.sh/capacity-type")
        az = get_label_value(node, "topology.kubernetes.io/zone")
        ip = get_node_ip(node)
        instance_id = get_instance_id(node)

        if include_subnets:
            subnet = get_subnet_from_labels(node)
            rows.append(
                [
                    name,
                    status,
                    taints,
                    age,
                    instance_type,
                    nodepool,
                    capacity,
                    subnet,
                    az,
                    ip,
                    instance_id,
                ]
            )
        else:
            rows.append(
                [
                    name,
                    status,
                    taints,
                    age,
                    instance_type,
                    nodepool,
                    capacity,
                    az,
                    ip,
                    instance_id,
                ]
            )

    if include_subnets:
        # Fill subnet from EC2 when labels did not expose it (needs aws CLI + creds).
        region = ""
        for node in nodes:
            region = get_region_from_node(node)
            if region:
                break
        missing_ids = [
            row[-1] for row in rows if row[7] == "<none>" and row[-1] != "<none>"
        ]
        if missing_ids and region:
            id_to_subnet = fetch_subnet_ids_from_aws(list(dict.fromkeys(missing_ids)), region)
            for row in rows:
                if row[7] == "<none>" and row[-1] in id_to_subnet:
                    row[7] = id_to_subnet[row[-1]]

        if not region:
            region = os.environ.get("AWS_REGION") or os.environ.get("AWS_DEFAULT_REGION") or ""

        # Subnet column holds subnet id until we resolve Name tags (one EC2 query per unique id, batched).
        subnet_ids_for_names = [
            row[7] for row in rows if row[7] != "<none>" and row[7].startswith("subnet-")
        ]
        subnet_id_to_name: Dict[str, str] = {}
        if subnet_ids_for_names and region:
            subnet_id_to_name = fetch_subnet_id_to_name(subnet_ids_for_names, region)
        for row in rows:
            sid = row[7]
            if sid != "<none>" and sid.startswith("subnet-"):
                row[7] = subnet_id_to_name.get(sid, sid)

    # Sort rows by nodepool (index 5)
    rows.sort(key=lambda row: row[5])

    # Calculate column widths
    headers = [
        "NAME",
        "STATUS",
        "TAINTS",
        "AGE",
        "INSTANCE_TYPE",
        "NODEPOOL",
        "CAPACITY",
    ]
    if include_subnets:
        headers.append("SUBNET_NAME")
    headers.extend(["AZ", "IP", "INSTANCE_ID"])
    widths = [len(header) for header in headers]

    for row in rows:
        for i, cell in enumerate(row):
            widths[i] = max(widths[i], len(str(cell)))

    # Print header
    header_format = "  ".join(f"{{:<{w}}}" for w in widths)
    print(header_format.format(*headers))

    # Print rows
    for row in rows:
        print(header_format.format(*row))


def main(ctx: str, *, include_subnets: bool) -> None:
    """Main function."""
    nodes = get_nodes_data(ctx)
    print_nodes_table(nodes, include_subnets=include_subnets)


def _current_kubectl_context() -> str:
    result = subprocess.run(
        ["kubectl", "config", "current-context"],
        capture_output=True,
        text=True,
        check=True,
    )
    return result.stdout.strip()


if __name__ == "__main__":
    parser = argparse.ArgumentParser(
        description="Print Kubernetes nodes in a table (optional AWS subnet names).",
    )
    parser.add_argument(
        "context",
        nargs="?",
        default=None,
        help="kubectl context (default: current context from kubectl config)",
    )
    parser.add_argument(
        "--include-subnets",
        action="store_true",
        help="Include SUBNET_NAME and resolve names via AWS EC2 (requires aws CLI + creds).",
    )
    args = parser.parse_args()
    ctx = args.context if args.context is not None else _current_kubectl_context()
    main(ctx, include_subnets=args.include_subnets)

